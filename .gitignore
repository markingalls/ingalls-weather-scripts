# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.mypy_cache/
.ipynb_checkpoints/

# OS cruft
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Secrets / local config
.env
*.local

# --- columbia-basin-alerts-map ---
# alerts_with_zones.json is live data fetch_alerts.py regenerates every run --
# committing it just creates noise. The rendered map images are outputs too,
# not source -- regenerate with build_map.py rather than tracking them.
columbia-basin-alerts-map/alerts_with_zones.json
columbia-basin-alerts-map/columbia_basin_alerts*.png

# --- western-us-noaa-outlooks ---
# build_map.py fetches its source KML/KMZ live; data/ only holds files
# dropped there for a --file override (testing / a source being down), and
# the rendered PNGs are outputs -- neither is source, so don't track them.
western-us-noaa-outlooks/data/*.kml
western-us-noaa-outlooks/data/*.kmz
western-us-noaa-outlooks/output/*.png

# --- miles-city-wm6-temps ---
# build_map.py fetches its source grids live; data/ only holds saved
# snapshots for a --file override (testing / avoiding a ~1 GB re-fetch),
# and the rendered PNGs are outputs -- neither is source, so don't track them.
miles-city-wm6-temps/data/*.npz
miles-city-wm6-temps/output/*.png
